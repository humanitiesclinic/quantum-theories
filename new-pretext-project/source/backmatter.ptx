<?xml version="1.0" encoding="UTF-8"?>
<!-- Backmatter for Quantum Theories: The Missing Big Picture -->

<backmatter xmlns:xi="http://www.w3.org/2001/XInclude" xml:id="backmatter">

  <!-- Appendix A: Notation -->
  <appendix xml:id="appendix-notation">
    <title>Notation and Conventions</title>
    <section>
      <title>Quantum Notation</title>
      <ul>
        <li><m>\ket{\psi}</m>: state vector (ket)</li>
        <li><m>\bra{\psi}</m>: dual vector (bra)</li>
        <li><m>\braket{\phi}{\psi}</m>: inner product</li>
        <li><m>\AA, \HH, \LL, \SS</m>: operators</li>
        <li><m>\expect{\AA}</m>: expectation value</li>
        <li><m>\comm{\AA}{\BB}</m>: commutator</li>
      </ul>
    </section>
  </appendix>

  <!-- Appendix B: Mathematical Tools -->
  <appendix xml:id="appendix-math">
    <title>Essential Mathematical Tools</title>
    <section>
      <title>Linear Algebra</title>
      <p>Vector spaces, eigenvalues, matrix diagonalization, tensor products, functional analysis.</p>
    </section>
    <section>
      <title>Special Functions</title>
      <p>Hermite, Legendre, Bessel functions, and spherical harmonics used throughout.</p>
    </section>
  </appendix>

  <!-- Appendix C: Constants -->
  <appendix xml:id="appendix-constants">
    <title>Physical Constants and Conversion Factors</title>
    <section>
      <title>Fundamental Constants</title>
      <ul>
        <li><m>\hbar = 1.054 \times 10^{-34}</m> J·s</li>
        <li><m>c = 3 \times 10^8</m> m/s</li>
        <li><m>m_e = 9.109 \times 10^{-31}</m> kg</li>
        <li><m>a_0 = 0.529 \text{ Å}</m> (Bohr radius)</li>
      </ul>
    </section>
  </appendix>

