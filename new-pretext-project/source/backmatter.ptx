  <!-- Glossary -->
  <glossary xml:id="glossary">
    <title>Glossary of Terms</title>
    <gi><title>Angular Momentum</title><p>Intrinsic or orbital rotational property, quantized in units of <m>\hbar</m>.</p></gi>
    <gi><title>Born Rule</title><p>Probability <m>P(a_n) = |\braket{a_n}{\psi}|^2</m> of measuring eigenvalue.</p></gi>
    <gi><title>Boson</title><p>Integer spin particle with symmetric wavefunction.</p></gi>
    <gi><title>Commutator</title><p><m>[\AA, \BB] = \AA\BB - \BB\AA</m>, measures non-commutativity.</p></gi>
    <gi><title>Decoherence</title><p>Loss of quantum coherence to environment.</p></gi>
    <gi><title>Eigenvalue</title><p>Possible measurement outcome for observable.</p></gi>
    <gi><title>Entanglement</title><p>Correlation in composite systems beyond product states.</p></gi>
    <gi><title>Fermion</title><p>Half-integer spin particle with antisymmetric wavefunction.</p></gi>
    <gi><title>Fock Space</title><p>Hilbert space for variable particle number.</p></gi>
    <gi><title>Hamiltonian</title><p>Total energy operator <m>\HH = \hat{T} + \hat{V}</m>.</p></gi>
    <gi><title>Hilbert Space</title><p>Complete complex vector space for quantum states.</p></gi>
    <gi><title>Pauli Exclusion</title><p>No two fermions in identical quantum state.</p></gi>
    <gi><title>Perturbation Theory</title><p>Approximation in powers of small coupling.</p></gi>
    <gi><title>Schrödinger Equation</title><p>Master equation: <m>i\hbar d\ket{\psi}/dt = \HH\ket{\psi}</m>.</p></gi>
    <gi><title>Spin</title><p>Intrinsic angular momentum, purely quantum.</p></gi>
    <gi><title>Tunneling</title><p>Quantum particle penetration into classically forbidden region.</p></gi>
    <gi><title>Uncertainty Principle</title><p><m>\Delta A \cdot \Delta B \geq \frac{\hbar}{2}|\expect{[\AA, \BB]}|</m>.</p></gi>
  </glossary>

</backmatter>
